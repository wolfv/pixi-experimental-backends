{%- if is_bash %}
cd "{{ source_dir }}"

export GRADLE_USER_HOME="$SRC_DIR/.gradle_home"

{% if use_wrapper -%}
chmod +x gradlew 2>/dev/null || true
./gradlew --no-daemon {{ tasks | join(" ") }} {{ extra_args | join(" ") }}
{%- else -%}
gradle --no-daemon {{ tasks | join(" ") }} {{ extra_args | join(" ") }}
{%- endif %}

# Auto-install Application plugin distribution to PREFIX if present
for dist_dir in build/install/*/; do
    if [ -d "$dist_dir" ]; then
        [ -d "${dist_dir}bin" ] && cp -r "${dist_dir}bin/." "$PREFIX/bin/"
        if [ -d "${dist_dir}lib" ]; then
            mkdir -p "$PREFIX/share/java"
            cp "${dist_dir}lib/"*.jar "$PREFIX/share/java/"
        fi
    fi
done
{%- else %}
cd /d "{{ source_dir }}"

set "GRADLE_USER_HOME=%SRC_DIR%\.gradle_home"

{% if use_wrapper -%}
gradlew.bat --no-daemon {{ tasks | join(" ") }} {{ extra_args | join(" ") }}
{%- else -%}
gradle --no-daemon {{ tasks | join(" ") }} {{ extra_args | join(" ") }}
{%- endif %}
@if errorlevel 1 exit 1

for /d %%d in (build\install\*) do (
    if exist "%%d\bin" (
        xcopy /E /I /Y "%%d\bin" "%PREFIX%\bin\"
        @if errorlevel 1 exit 1
    )
    if exist "%%d\lib" (
        if not exist "%PREFIX%\share\java" mkdir "%PREFIX%\share\java"
        xcopy /I /Y "%%d\lib\*.jar" "%PREFIX%\share\java\"
        @if errorlevel 1 exit 1
    )
)
{%- endif %}
