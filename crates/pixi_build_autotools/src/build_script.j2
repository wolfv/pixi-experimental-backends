{%- set is_cmd_exe = build_platform == "windows" -%}
{%- macro env(key) -%}
{%- if is_cmd_exe %}{{ "%" ~ key ~ "%" }}{% else %}{{ "$" ~ key }}{% endif -%}
{% endmacro -%}

{# Set up common variables #}
{%- set prefix = "%LIBRARY_PREFIX%" if is_cmd_exe else "$PREFIX" -%}

{# Set up default configure arguments #}
{%- set configure_args = [
    "--prefix=" ~ prefix,
] + extra_configure_args
-%}

{% if is_cmd_exe -%}
{# Windows: run autotools through MSYS2 shell (m2-bash) like conda-forge #}

{# Run autoreconf if requested #}
{% if autoreconf -%}
set MSYSTEM=MINGW%ARCH%
m2-bash -lc "autoreconf -vfi"
@if errorlevel 1 exit 1
{% endif -%}

set MSYSTEM=MINGW%ARCH%
m2-bash -lc "cd \"$SRC_DIR\" && ./configure {{ configure_args | join(' ') }}"
@if errorlevel 1 exit 1

m2-bash -lc "cd \"$SRC_DIR\" && make -j%CPU_COUNT% {{ extra_make_args | join(' ') }}"
@if errorlevel 1 exit 1

m2-bash -lc "cd \"$SRC_DIR\" && make install {{ extra_make_args | join(' ') }}"
@if errorlevel 1 exit 1

{% else -%}

{# Run autoreconf if requested #}
{% if autoreconf -%}
autoreconf -vfi
{% endif -%}

cd "{{ source_dir }}"

if [ ! -f "configure" ]; then
    echo "Error: No configure script found. Set autoreconf = true in the backend config if this project needs autoreconf."
    exit 1
fi

./configure {{ configure_args | join(" \\\n    ") }}

make -j${CPU_COUNT:-1} {{ extra_make_args | join(" ") }}

make install {{ extra_make_args | join(" ") }}

{% endif -%}
